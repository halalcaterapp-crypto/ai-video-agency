# ─────────────────────────────────────────────────────────────────────────────
#  AI Video Agency — Environment Variables
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (TTS) ─────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Higgsfield ───────────────────────────────────────────────────────────────
# Get your key & secret at: https://cloud.higgsfield.ai (API section)
# Auth header format: "Key {HIGGSFIELD_API_KEY}:{HIGGSFIELD_API_SECRET}"
HIGGSFIELD_API_KEY=your_higgsfield_key_here
HIGGSFIELD_API_SECRET=your_higgsfield_secret_here

# ── SendGrid (email delivery) ────────────────────────────────────────────────
# Create a free account at: https://sendgrid.com/
# Generate a key at: Settings → API Keys → Create API Key (Mail Send permission)
SENDGRID_API_KEY=SG....

# ── Sender identity ──────────────────────────────────────────────────────────
# Must be a verified sender in your SendGrid account
FROM_EMAIL=studio@youragency.com
FROM_NAME=AI Video Studio

# ── ImageMagick (optional override) ─────────────────────────────────────────
# Only needed if `convert` / `magick` is not on PATH automatically
# macOS example:   IMAGEMAGICK_BINARY=/opt/homebrew/bin/convert
# Windows example: IMAGEMAGICK_BINARY=C:\Program Files\ImageMagick-7.1.1-Q16-HDRI\magick.exe
# IMAGEMAGICK_BINARY=
